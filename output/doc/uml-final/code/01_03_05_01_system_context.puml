@startuml
    !pragma layout smetana

skinparam BackgroundColor white
skinparam Shadowing false
skinparam DefaultFontName Arial
skinparam ArrowColor #334155
skinparam PackageBorderColor #0f172a
skinparam PackageBackgroundColor #f8fafc
skinparam ComponentBorderColor #1d4ed8
skinparam ComponentBackgroundColor #eff6ff
skinparam DatabaseBorderColor #0f766e
skinparam DatabaseBackgroundColor #ecfeff
skinparam ActorBorderColor #0f172a
skinparam ActorBackgroundColor #f8fafc
skinparam UsecaseBorderColor #0369a1
skinparam UsecaseBackgroundColor #f0f9ff
skinparam NoteBackgroundColor #fff7ed
skinparam NoteBorderColor #ea580c
skinparam SequenceLifeLineBorderColor #94a3b8
skinparam SequenceParticipantBorderColor #1e293b
skinparam SequenceParticipantBackgroundColor #f8fafc
skinparam SequenceBoxBorderColor #93c5fd
skinparam SequenceBoxBackgroundColor #eff6ff
skinparam ActivityBorderColor #1e40af
skinparam ActivityBackgroundColor #eff6ff
skinparam classAttributeIconSize 0
skinparam linetype ortho

    title [3.5.1] Sơ đồ ngữ cảnh hệ thống CRM SaaS
    left to right direction

    actor "Nhân viên Sales" as Sales
    actor "Nhân viên CSKH" as CSKH
    actor "Nhân viên Marketing" as Marketing
    actor "Giám đốc" as Director
    actor "Admin" as Admin

    rectangle "Hệ thống CRM SaaS" as CRM {
      usecase "Quản lý khách hàng 360°" as UC_Customer
      usecase "Quản lý giao dịch" as UC_Transaction
      usecase "Ticket & chăm sóc khách hàng" as UC_Ticket
      usecase "Campaign & Automation" as UC_Campaign
      usecase "Dashboard & báo cáo" as UC_Analytics
      usecase "Quản trị hệ thống" as UC_Admin
      usecase "Cấu hình POS Sync" as UC_POS
    }

    cloud "Resend / Email Provider" as EmailProvider
    cloud "SMS Provider" as SMSProvider
    cloud "POS System API" as POS
    database "Supabase Cloud\n(PostgreSQL + Auth + Realtime + Storage)" as Supabase

    Sales --> UC_Customer
    Sales --> UC_Transaction
    Sales --> UC_Ticket

    CSKH --> UC_Ticket
    Marketing --> UC_Campaign
    Director --> UC_Analytics
    Admin --> UC_Admin
    Admin --> UC_POS

    UC_Campaign --> EmailProvider
    UC_Campaign --> SMSProvider
    UC_POS --> POS

    UC_Customer --> Supabase
    UC_Transaction --> Supabase
    UC_Ticket --> Supabase
    UC_Campaign --> Supabase
    UC_Analytics --> Supabase
    UC_Admin --> Supabase
    UC_POS --> Supabase

    note bottom of CRM
      Ranh giới hệ thống bao gồm 8 module:
      M01 Auth, M02 Customer, M03 Transaction,
      M04 Ticket, M05 Automation, M06 Campaign,
      M07 Analytics, M08 Admin.
    end note
    @enduml
