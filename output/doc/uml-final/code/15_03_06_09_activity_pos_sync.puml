    title [3.6.9] Biểu đồ hoạt động đồng bộ dữ liệu POS (MVP Polling Sync)
    start
    :Admin cấu hình POS provider,\nAPI endpoint, API key, sync_interval;
    :Lưu cấu hình vào app_settings;
    if (Test connection thành công?) then (Có)
      :Kích hoạt lịch polling sync;
      :Đến chu kỳ định sẵn,\nCRM gọi POS API lấy giao dịch mới;
      if (Có giao dịch mới?) then (Có)
        :Chuẩn hóa payload;
        :Upsert transactions + customer rollup;
        :Ghi pos_sync_logs và audit_logs;
      else (Không)
        :Ghi log không có dữ liệu mới;
      endif
    else (Không)
      :Hiển thị lỗi kết nối và giữ trạng thái cấu hình;
    endif
    stop
