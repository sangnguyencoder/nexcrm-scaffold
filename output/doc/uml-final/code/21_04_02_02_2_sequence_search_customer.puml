    title [4.2.2.2] Sequence - Tìm kiếm thông tin khách hàng
    actor Sales
    participant Browser
    participant "CustomerListPage" as UI
    participant "TanStack Query" as Query
    participant "customerService" as CustomerService
    database "Supabase DB (customers)" as DB

    Sales -> Browser : Nhập từ khóa / bộ lọc
    Browser -> UI : onSearchChange()
    UI -> Query : useCustomersQuery(filters)
    Query -> CustomerService : getList(params)
    CustomerService -> DB : SELECT customers WHERE org_id = current_org\nAND filters/search apply
    DB --> CustomerService : customer rows
    CustomerService --> Query : Customer[]
    Query --> UI : cache + render list
    UI --> Browser : Hiển thị kết quả tìm kiếm
    @enduml
