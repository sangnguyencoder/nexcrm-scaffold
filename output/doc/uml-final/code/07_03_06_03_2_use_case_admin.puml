@startuml
    !pragma layout smetana

skinparam BackgroundColor white
skinparam Shadowing false
skinparam DefaultFontName Arial
skinparam ArrowColor #334155
skinparam PackageBorderColor #0f172a
skinparam PackageBackgroundColor #f8fafc
skinparam ComponentBorderColor #1d4ed8
skinparam ComponentBackgroundColor #eff6ff
skinparam DatabaseBorderColor #0f766e
skinparam DatabaseBackgroundColor #ecfeff
skinparam ActorBorderColor #0f172a
skinparam ActorBackgroundColor #f8fafc
skinparam UsecaseBorderColor #0369a1
skinparam UsecaseBackgroundColor #f0f9ff
skinparam NoteBackgroundColor #fff7ed
skinparam NoteBorderColor #ea580c
skinparam SequenceLifeLineBorderColor #94a3b8
skinparam SequenceParticipantBorderColor #1e293b
skinparam SequenceParticipantBackgroundColor #f8fafc
skinparam SequenceBoxBorderColor #93c5fd
skinparam SequenceBoxBackgroundColor #eff6ff
skinparam ActivityBorderColor #1e40af
skinparam ActivityBackgroundColor #eff6ff
skinparam classAttributeIconSize 0
skinparam linetype ortho

    title [3.6.3.2] Phân rã Use Case Admin
    left to right direction

    actor "Admin" as Admin

    rectangle "Module Admin CRM" {
      usecase "Xác thực đăng nhập" as Login
      usecase "Quản trị người dùng" as ManageUser
      usecase "Cấu hình hệ thống" as ManageSettings
      usecase "Xem audit logs" as ViewAudit
      usecase "Cấu hình POS Integration" as ConfigurePOS
      usecase "Tạo user / gán role" as CreateUser
      usecase "Kích hoạt / vô hiệu hóa tài khoản" as ToggleUser
      usecase "Cấu hình email / SMS provider" as ConfigureProvider
      usecase "Cập nhật thông tin tổ chức" as UpdateOrg
      usecase "Kiểm tra kết nối POS" as TestPOS
      usecase "Xem log đồng bộ POS" as ViewPOSLog
    }

    Admin --> ManageUser
    Admin --> ManageSettings
    Admin --> ViewAudit
    Admin --> ConfigurePOS

    ManageUser ..> Login : <<include>>
    ManageUser ..> CreateUser : <<include>>
    ManageUser ..> ToggleUser : <<include>>

    ManageSettings ..> Login : <<include>>
    ManageSettings ..> ConfigureProvider : <<include>>
    ManageSettings ..> UpdateOrg : <<include>>

    ViewAudit ..> Login : <<include>>

    ConfigurePOS ..> Login : <<include>>
    ConfigurePOS ..> TestPOS : <<include>>
    ConfigurePOS ..> ViewPOSLog : <<include>>
    @enduml
