@startuml

skinparam BackgroundColor white
skinparam Shadowing false
skinparam DefaultFontName Arial
skinparam ArrowColor #334155
skinparam PackageBorderColor #0f172a
skinparam PackageBackgroundColor #f8fafc
skinparam ComponentBorderColor #1d4ed8
skinparam ComponentBackgroundColor #eff6ff
skinparam DatabaseBorderColor #0f766e
skinparam DatabaseBackgroundColor #ecfeff
skinparam ActorBorderColor #0f172a
skinparam ActorBackgroundColor #f8fafc
skinparam UsecaseBorderColor #0369a1
skinparam UsecaseBackgroundColor #f0f9ff
skinparam NoteBackgroundColor #fff7ed
skinparam NoteBorderColor #ea580c
skinparam SequenceLifeLineBorderColor #94a3b8
skinparam SequenceParticipantBorderColor #1e293b
skinparam SequenceParticipantBackgroundColor #f8fafc
skinparam SequenceBoxBorderColor #93c5fd
skinparam SequenceBoxBackgroundColor #eff6ff
skinparam ActivityBorderColor #1e40af
skinparam ActivityBackgroundColor #eff6ff
skinparam classAttributeIconSize 0
skinparam linetype ortho

    title [4.2.2.2] Sequence - Giám đốc xem và xuất báo cáo
    actor Director
    participant Browser
    participant "DashboardPage / ReportsPage" as UI
    participant "dashboardService" as DashboardService
    participant "reportService / exportService" as ReportService
    database "Supabase DB / RPC" as DB

    Director -> Browser : Mở dashboard và chọn kỳ báo cáo
    Browser -> UI : đổi bộ lọc thời gian
    UI -> DashboardService : getDashboardSnapshot(range)
    DashboardService -> DB : RPC get_dashboard_snapshot(range)
    DB --> DashboardService : KPI + chart data + top customers
    DashboardService --> UI : dashboard data
    UI --> Browser : Hiển thị KPI và biểu đồ
    alt Xuất báo cáo
      Director -> UI : Chọn Export CSV/Excel
      UI -> ReportService : export(range, format)
      ReportService -> DB : lấy dataset cuối cùng
      DB --> ReportService : rows
      ReportService --> UI : Blob file
      UI --> Browser : Trigger download
    end
    @enduml
