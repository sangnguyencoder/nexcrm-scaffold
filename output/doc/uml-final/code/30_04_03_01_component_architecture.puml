@startuml
    !pragma layout smetana

skinparam BackgroundColor white
skinparam Shadowing false
skinparam DefaultFontName Arial
skinparam ArrowColor #334155
skinparam PackageBorderColor #0f172a
skinparam PackageBackgroundColor #f8fafc
skinparam ComponentBorderColor #1d4ed8
skinparam ComponentBackgroundColor #eff6ff
skinparam DatabaseBorderColor #0f766e
skinparam DatabaseBackgroundColor #ecfeff
skinparam ActorBorderColor #0f172a
skinparam ActorBackgroundColor #f8fafc
skinparam UsecaseBorderColor #0369a1
skinparam UsecaseBackgroundColor #f0f9ff
skinparam NoteBackgroundColor #fff7ed
skinparam NoteBorderColor #ea580c
skinparam SequenceLifeLineBorderColor #94a3b8
skinparam SequenceParticipantBorderColor #1e293b
skinparam SequenceParticipantBackgroundColor #f8fafc
skinparam SequenceBoxBorderColor #93c5fd
skinparam SequenceBoxBackgroundColor #eff6ff
skinparam ActivityBorderColor #1e40af
skinparam ActivityBackgroundColor #eff6ff
skinparam classAttributeIconSize 0
skinparam linetype ortho

    title [4.3.1] Component Architecture 5 tầng
    top to bottom direction

    package "Tầng 1 - Pages" {
      [DashboardPage]
      [CustomerListPage]
      [CustomerDetailPage]
      [TransactionListPage]
      [TicketListPage]
      [CampaignListPage]
      [AutomationPage]
      [DealPipelinePage]
      [ReportsPage]
      [Admin Pages]
    }

    package "Tầng 2 - Layouts" {
      [AppLayout]
      [AuthLayout]
      [FullscreenLayout]
    }

    package "Tầng 3 - Reusable Components" {
      [UI Atoms]
      [Domain Widgets]
      [Shared Navigation]
    }

    package "Tầng 4 - Hooks & State" {
      [useNexcrmQueries]
      [Mutation Hooks]
      [useAuth / usePermission]
      [useRealtimeTickets]
      [useRealtimeNotifications]
      [Zustand Auth Store]
      [TanStack Query Client]
    }

    package "Tầng 5 - Services" {
      [authService]
      [customerService]
      [transactionService]
      [ticketService]
      [campaignService]
      [automationService]
      [dashboardService]
      [dealService]
      [taskService]
      [settingsService]
      [notificationService]
      [posSyncService]
    }

    [DashboardPage] --> [AppLayout]
    [CustomerListPage] --> [AppLayout]
    [CustomerDetailPage] --> [AppLayout]
    [Admin Pages] --> [AppLayout]

    [AppLayout] --> [Shared Navigation]
    [CustomerDetailPage] --> [Domain Widgets]
    [ReportsPage] --> [Domain Widgets]
    [TicketListPage] --> [UI Atoms]

    [DashboardPage] --> [useNexcrmQueries]
    [CustomerListPage] --> [useNexcrmQueries]
    [TicketListPage] --> [useRealtimeTickets]
    [AppLayout] --> [useAuth / usePermission]
    [useNexcrmQueries] --> [TanStack Query Client]
    [useAuth / usePermission] --> [Zustand Auth Store]

    [useNexcrmQueries] --> [customerService]
    [useNexcrmQueries] --> [transactionService]
    [useNexcrmQueries] --> [ticketService]
    [useNexcrmQueries] --> [campaignService]
    [useNexcrmQueries] --> [dashboardService]
    [Mutation Hooks] --> [dealService]
    [Mutation Hooks] --> [taskService]
    [useAuth / usePermission] --> [authService]
    [useRealtimeNotifications] --> [notificationService]
    [Admin Pages] --> [settingsService]
    [Admin Pages] --> [posSyncService]
    @enduml
