    title [4.2.2.2] Sequence - CSKH xử lý phản hồi khách hàng
    actor CSKH
    participant Browser
    participant "TicketPage" as UI
    participant "ticketService" as TicketService
    participant "notificationService" as NotificationService
    database "Supabase DB" as DB

    CSKH -> Browser : Tạo phiếu phản hồi mới
    Browser -> UI : Submit feedback form
    UI -> TicketService : create(ticket payload)
    TicketService -> DB : INSERT support_tickets
    DB -> DB : generate ticket_code
    DB --> TicketService : ticket created
    TicketService --> UI : ticket detail
    CSKH -> UI : Thêm comment và cập nhật trạng thái
    UI -> TicketService : addComment()/updateStatus()
    TicketService -> DB : INSERT ticket_comments / UPDATE support_tickets
    UI -> NotificationService : notify assigned users
    NotificationService -> DB : INSERT notifications
    UI --> Browser : Hiển thị phản hồi đã được ghi nhận
    @enduml
