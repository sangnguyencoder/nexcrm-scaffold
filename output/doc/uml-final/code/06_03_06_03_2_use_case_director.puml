@startuml
    !pragma layout smetana

skinparam BackgroundColor white
skinparam Shadowing false
skinparam DefaultFontName Arial
skinparam ArrowColor #334155
skinparam PackageBorderColor #0f172a
skinparam PackageBackgroundColor #f8fafc
skinparam ComponentBorderColor #1d4ed8
skinparam ComponentBackgroundColor #eff6ff
skinparam DatabaseBorderColor #0f766e
skinparam DatabaseBackgroundColor #ecfeff
skinparam ActorBorderColor #0f172a
skinparam ActorBackgroundColor #f8fafc
skinparam UsecaseBorderColor #0369a1
skinparam UsecaseBackgroundColor #f0f9ff
skinparam NoteBackgroundColor #fff7ed
skinparam NoteBorderColor #ea580c
skinparam SequenceLifeLineBorderColor #94a3b8
skinparam SequenceParticipantBorderColor #1e293b
skinparam SequenceParticipantBackgroundColor #f8fafc
skinparam SequenceBoxBorderColor #93c5fd
skinparam SequenceBoxBackgroundColor #eff6ff
skinparam ActivityBorderColor #1e40af
skinparam ActivityBackgroundColor #eff6ff
skinparam classAttributeIconSize 0
skinparam linetype ortho

    title [3.6.3.2] Phân rã Use Case Giám đốc
    left to right direction

    actor "Giám đốc" as Director

    rectangle "Module Analytics CRM" {
      usecase "Xác thực đăng nhập" as Login
      usecase "Xem dashboard CRM" as ViewDashboard
      usecase "Xem báo cáo doanh số" as ViewReport
      usecase "Lọc theo khoảng thời gian" as FilterByDate
      usecase "Xem KPI tổng hợp" as ViewKPI
      usecase "Xem top khách hàng" as ViewTopCustomers
      usecase "Xem hiệu quả campaign" as ViewCampaignPerformance
      usecase "Xuất CSV / Excel" as ExportReport
    }

    Director --> ViewDashboard
    Director --> ViewReport

    ViewDashboard ..> Login : <<include>>
    ViewDashboard ..> FilterByDate : <<include>>
    ViewDashboard ..> ViewKPI : <<include>>
    ViewDashboard ..> ViewTopCustomers : <<include>>

    ViewReport ..> Login : <<include>>
    ViewReport ..> FilterByDate : <<include>>
    ViewReport ..> ViewCampaignPerformance : <<include>>
    ViewReport ..> ExportReport : <<include>>
    @enduml
