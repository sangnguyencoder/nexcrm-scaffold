@startuml
    !pragma layout smetana

skinparam BackgroundColor white
skinparam Shadowing false
skinparam DefaultFontName Arial
skinparam ArrowColor #334155
skinparam PackageBorderColor #0f172a
skinparam PackageBackgroundColor #f8fafc
skinparam ComponentBorderColor #1d4ed8
skinparam ComponentBackgroundColor #eff6ff
skinparam DatabaseBorderColor #0f766e
skinparam DatabaseBackgroundColor #ecfeff
skinparam ActorBorderColor #0f172a
skinparam ActorBackgroundColor #f8fafc
skinparam UsecaseBorderColor #0369a1
skinparam UsecaseBackgroundColor #f0f9ff
skinparam NoteBackgroundColor #fff7ed
skinparam NoteBorderColor #ea580c
skinparam SequenceLifeLineBorderColor #94a3b8
skinparam SequenceParticipantBorderColor #1e293b
skinparam SequenceParticipantBackgroundColor #f8fafc
skinparam SequenceBoxBorderColor #93c5fd
skinparam SequenceBoxBackgroundColor #eff6ff
skinparam ActivityBorderColor #1e40af
skinparam ActivityBackgroundColor #eff6ff
skinparam classAttributeIconSize 0
skinparam linetype ortho

    title [4.2.2.1] Class Diagram - Service Layer
    hide circle
    left to right direction

    class AuthService {
      +signIn(email, password)
      +signOut()
      +resetPassword(email)
      +updatePassword(data)
    }
    class CustomerService {
      +getList(params)
      +getById(id)
      +create(data)
      +update(id, data)
      +softDelete(id)
      +exportCSV(orgId)
    }
    class TransactionService {
      +create(data)
      +getByCustomer(customerId)
      +updateStatus(id, status)
    }
    class TicketService {
      +getList(params)
      +getById(id)
      +create(data)
      +update(id, data)
      +updateStatus(id, status)
      +addComment(ticketId, content, isInternal)
    }
    class CampaignService {
      +getList(params)
      +create(data)
      +update(id, data)
      +schedule(id, scheduledAt)
      +dispatch(id)
    }
    class AutomationService {
      +getAll()
      +create(data)
      +update(id, data)
      +toggleActive(id, isActive)
      +runNow(id)
    }
    class DashboardService {
      +getDashboardSnapshot(range)
      +getRevenueChart(range)
      +getTopCustomers(range)
    }
    class DealService {
      +getList(params)
      +getById(id)
      +create(data)
      +update(id, data)
      +updateStage(id, stage)
    }
    class TaskService {
      +getList(params)
      +create(data)
      +update(id, data)
      +complete(id)
      +delete(id)
    }
    class SettingsService {
      +getSettings()
      +updateSettings(data)
      +testPosConnection()
    }
    class PosSyncService {
      +getConfig()
      +saveConfig(data)
      +runPollingSync()
      +getLogs()
    }
    class NotificationService {
      +getInbox()
      +markRead(id)
      +broadcastRealtime()
    }
    class SupabaseClient

    AuthService --> SupabaseClient
    CustomerService --> SupabaseClient
    TransactionService --> SupabaseClient
    TicketService --> SupabaseClient
    CampaignService --> SupabaseClient
    AutomationService --> SupabaseClient
    DashboardService --> SupabaseClient
    DealService --> SupabaseClient
    TaskService --> SupabaseClient
    SettingsService --> SupabaseClient
    PosSyncService --> SupabaseClient
    NotificationService --> SupabaseClient

    CustomerService ..> Customer
    TransactionService ..> Transaction
    TicketService ..> SupportTicket
    CampaignService ..> Campaign
    AutomationService ..> AutomationRule
    DashboardService ..> Customer
    DashboardService ..> Transaction
    DealService ..> Deal
    TaskService ..> Task
    SettingsService ..> Organization
    PosSyncService ..> Transaction
    NotificationService ..> Profile
    @enduml
