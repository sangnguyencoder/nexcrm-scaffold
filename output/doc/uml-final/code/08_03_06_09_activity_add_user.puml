    title [3.6.9] Biểu đồ hoạt động thêm người dùng
    start
    :Admin truy cập /admin/users;
    :Nhấn "Thêm người dùng";
    :Nhập full_name, email, role, org và trạng thái active;
    if (Dữ liệu hợp lệ?) then (Có)
      :profileService/manage-profile-user\nkiểm tra email trùng;
      if (Email đã tồn tại?) then (Có)
        :Hiển thị lỗi trùng email;
        stop
      else (Không)
        :Tạo auth user;
        :Tạo bản ghi profiles;
        :Ghi audit_logs;
        :Hiển thị tài khoản mới trong bảng user;
        stop
      endif
    else (Không)
      :Hiển thị lỗi validate;
      stop
    endif
    @enduml
