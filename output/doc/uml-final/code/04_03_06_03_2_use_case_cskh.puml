@startuml
    !pragma layout smetana

skinparam BackgroundColor white
skinparam Shadowing false
skinparam DefaultFontName Arial
skinparam ArrowColor #334155
skinparam PackageBorderColor #0f172a
skinparam PackageBackgroundColor #f8fafc
skinparam ComponentBorderColor #1d4ed8
skinparam ComponentBackgroundColor #eff6ff
skinparam DatabaseBorderColor #0f766e
skinparam DatabaseBackgroundColor #ecfeff
skinparam ActorBorderColor #0f172a
skinparam ActorBackgroundColor #f8fafc
skinparam UsecaseBorderColor #0369a1
skinparam UsecaseBackgroundColor #f0f9ff
skinparam NoteBackgroundColor #fff7ed
skinparam NoteBorderColor #ea580c
skinparam SequenceLifeLineBorderColor #94a3b8
skinparam SequenceParticipantBorderColor #1e293b
skinparam SequenceParticipantBackgroundColor #f8fafc
skinparam SequenceBoxBorderColor #93c5fd
skinparam SequenceBoxBackgroundColor #eff6ff
skinparam ActivityBorderColor #1e40af
skinparam ActivityBackgroundColor #eff6ff
skinparam classAttributeIconSize 0
skinparam linetype ortho

    title [3.6.3.2] Phân rã Use Case Nhân viên CSKH
    left to right direction

    actor "Nhân viên CSKH" as CSKH

    rectangle "Module CSKH CRM" {
      usecase "Xác thực đăng nhập" as Login
      usecase "Quản lý ticket / phản hồi" as ManageTicket
      usecase "Quản lý chăm sóc khách hàng" as ManageCare
      usecase "Tạo ticket mới" as CreateTicket
      usecase "Phân loại mức ưu tiên" as ClassifyPriority
      usecase "Cập nhật trạng thái ticket" as UpdateTicketStatus
      usecase "Thêm comment nội bộ / công khai" as AddComment
      usecase "Ghi nhận mức hài lòng (CSAT)" as RecordCSAT
      usecase "Lập lịch follow-up" as ScheduleCare
      usecase "Theo dõi lịch sử tương tác" as TrackInteraction
      usecase "Nhận realtime update" as ReceiveRealtime
    }

    CSKH --> ManageTicket
    CSKH --> ManageCare

    ManageTicket ..> Login : <<include>>
    ManageTicket ..> CreateTicket : <<include>>
    ManageTicket ..> ClassifyPriority : <<include>>
    ManageTicket ..> UpdateTicketStatus : <<include>>
    ManageTicket ..> AddComment : <<include>>
    ManageTicket ..> RecordCSAT : <<include>>
    ManageTicket ..> ReceiveRealtime : <<include>>

    ManageCare ..> Login : <<include>>
    ManageCare ..> ScheduleCare : <<include>>
    ManageCare ..> TrackInteraction : <<include>>
    ManageCare ..> ReceiveRealtime : <<include>>
    @enduml
