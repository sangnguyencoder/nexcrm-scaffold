    title [3.6.9] Biểu đồ hoạt động đăng nhập
    start
    :Người dùng mở /login;
    :Nhập email và mật khẩu;
    if (Form hợp lệ?) then (Có)
      :React App gọi signInWithPassword();
      if (Xác thực thành công?) then (Có)
        :Tải profiles theo auth.uid();
        if (is_active = true?) then (Có)
          :Lưu session vào authStore/Zustand;
          :Điều hướng đến dashboard phù hợp vai trò;
          stop
        else (Không)
          :Thông báo tài khoản bị vô hiệu hóa;
          stop
        endif
      else (Không)
        :Thông báo sai email hoặc mật khẩu;
        stop
      endif
    else (Không)
      :Hiển thị lỗi validate;
      stop
    endif
