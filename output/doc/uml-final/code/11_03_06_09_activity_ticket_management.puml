    if (Tạo ticket mới?) then (Có)
      :Nhập customer, title, description,\ncategory, priority, channel;
      :ticketService.create();
      :Sinh ticket_code qua trigger;
      :Assign người phụ trách;
    endif
    :Theo dõi ticket ở Table hoặc Kanban;
    :Cập nhật trạng thái open -> in_progress -> pending -> resolved -> closed;
    :Thêm comment nội bộ / công khai;
    if (Đóng ticket?) then (Có)
      :Ghi satisfaction_score;
      :Ghi audit_logs;
    endif
    :Realtime broadcast cập nhật cho người dùng khác;
